#!/bin/bash
set -e

# Find the Dockerfile.
# Homebrew installs scripts to bin/ and data files to share/cage/ (one level up).
# For dev installs, the Dockerfile sits alongside this script.
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
SHARE_DIR="$(dirname "$SCRIPT_DIR")/share/cage"

if [ -f "$SHARE_DIR/Dockerfile" ]; then
  SCRIPT_DIR="$SHARE_DIR"
fi

echo "Rebuilding claude-isolated with latest claude-code..."
container build \
  --build-arg CACHE_BUST="$(date +%s)" \
  --tag claude-isolated \
  "$SCRIPT_DIR"

echo "Done. Current version:"
container run --rm claude-isolated claude --version
